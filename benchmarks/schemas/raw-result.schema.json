{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://garden.local/benchmarks/schemas/raw-result.schema.json",
  "title": "Benchmark raw result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "suite",
    "case_id",
    "condition",
    "repository_commit",
    "garden_commit",
    "plugin_version",
    "seed",
    "expected_outcome",
    "actual_outcome",
    "exit_code",
    "finding_ids",
    "stdout_sha256",
    "stderr_sha256",
    "elapsed_ns",
    "platform",
    "python_version"
  ],
  "properties": {
    "schema_version": { "const": "1" },
    "benchmark_version": { "const": "1" },
    "suite": {
      "enum": ["detection", "evidence", "mutations", "migration"]
    },
    "case_id": { "type": "string", "minLength": 1 },
    "condition": { "type": "string", "minLength": 1 },
    "repository_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "garden_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "plugin_version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    },
    "seed": { "type": "integer", "minimum": 0 },
    "expected_outcome": { "type": "string", "minLength": 1 },
    "actual_outcome": { "type": "string", "minLength": 1 },
    "exit_code": { "type": "integer" },
    "finding_ids": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "stdout_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "stderr_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "elapsed_ns": { "type": "integer", "minimum": 0 },
    "platform": { "type": "string", "minLength": 1 },
    "python_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+" }
  }
}
